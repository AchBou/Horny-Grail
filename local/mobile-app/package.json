{
  "name": "hornygrail-mobile-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:private-config": "node ./scripts/prepare-private-config.mjs",
    "predev": "npm run prepare:private-config",
    "dev": "vite dev --host",
    "prebuild": "npm run prepare:private-config",
    "build": "vite build",
    "preview": "vite preview --host",
    "check": "npm run build",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/cli": "8.4.0",
    "@capacitor/core": "8.4.0",
    "@sveltejs/adapter-static": "3.0.8",
    "@sveltejs/kit": "2.42.1",
    "svelte": "5.39.2"
  },
  "devDependencies": {
    "prettier": "3.6.2",
    "prettier-plugin-svelte": "3.4.0",
    "vite": "7.1.6"
  }
}
