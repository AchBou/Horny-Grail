{
    "name": "delete-test-01",
    "description": "delete-test-01-description",
    "version": "0.0.1",
    "private": true,
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.398.0",
        "@aws-sdk/client-s3": "^3.859.0",
        "@aws-sdk/client-secrets-manager": "^3.859.0",
        "@aws-sdk/lib-dynamodb": "^3.398.0",
        "@aws-sdk/s3-request-presigner": "^3.859.0"
    },
    "devDependencies": {
        "aws-sdk-client-mock": "^4.1.0",
        "jest": "^29.2.1"
    },
    "scripts": {
        "cloudfront:sync": "node ./scripts/sync-cloudfront-functions.mjs",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "sam:dev": "npm run cloudfront:sync && sam build && sam local start-api",
        "sam:deploy": "npm run cloudfront:sync && sam build && sam deploy"
    },
    "jest": {
        "testMatch": [
            "**/__tests__/**/*.[jt]s?(x)",
            "**/?(*.)+(spec|test).[jt]s?(x)",
            "**/__tests__/**/*.mjs?(x)",
            "**/?(*.)+(spec|test).mjs?(x)"
        ],
        "testPathIgnorePatterns": [
            "/node_modules/",
            "/.aws-sam/"
        ],
        "setupFiles": [
            "<rootDir>/jest.setup.mjs"
        ],
        "moduleFileExtensions": [
            "mjs",
            "js"
        ]
    }
}
